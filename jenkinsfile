pipeline {
    agent any

    stages {
        stage('Clone Code') {
            steps {
                git 'https://github.com/agrimtech-dev/test-cicd.git'
            }
        }

        stage('Build') {
            steps {
                echo "Build started..."
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                rm -rf /var/www/html/project/*
                cp -r * /var/www/html/project/
                '''
            }
        }
    }
}
