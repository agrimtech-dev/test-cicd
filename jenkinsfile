pipeline {
    agent any

    stages {
        stage('Clean') {
            steps {
                deleteDir()
            }
        }

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/agrimtech-dev/test-cicd.git'
            }
        }

        stage('Build') {
            steps {
                echo "Build started..."
                sh 'ls -la'
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                mkdir -p /var/www/html/project
                rm -rf /var/www/html/project/*
                cp -r * /var/www/html/project/
                '''
            }
        }
    }
}
